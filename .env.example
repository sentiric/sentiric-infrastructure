# ====================================================================
#          SENTIRIC PLATFORMU - ORTAM DEĞİŞKENLERİ (v3.0)
# ====================================================================

COMPOSE_PROJECT_NAME=sentiric

# ENV
ENV=development
NODE_ENV=development
LOG_LEVEL=info

# Loglama Bilgileri
RUST_LOG=debug,sentiric_media_service=debug,sentiric_sip_signaling_service=debug
ENABLE_DOTENV=true

# Docker ve Docker Compose Bilgileri
DOCKER_REGISTRY=ghcr.io/sentiric
TAG=latest
NETWORK_NAME=sentiric-net
COMPOSE_HTTP_TIMEOUT=300

# Sunucu Bilgileri
PUBLIC_IP=127.0.0.1

# ---

# Veritabanı Servisleri
POSTGRES_DB=sentiric_db
POSTGRES_DB_HOST=postgres
POSTGRES_DB_PORT=5432
POSTGRES_USER=sentiric
POSTGRES_PASSWORD=sentiric_pass
POSTGRES_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_DB_HOST}:${POSTGRES_DB_PORT}/${POSTGRES_DB}?sslmode=disable
SYSTEM_DB_URL=${POSTGRES_URL}

VECTOR_DB=sentiric_db
VECTOR_DB_HOST=qdrant
VECTOR_DB_PORT=6333
VECTOR_DB_COLLECTION_NAME=sentiric_kb
VECTOR_DB_COLLECTION_PREFIX=sentiric_kb_
VECTOR_DB_EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
VECTOR_DB_URL="${VECTOR_DB_HOST}:${VECTOR_DB_PORT}"

# Mesajlaşma Servisleri
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_DEFAULT_USER=sentiric
RABBITMQ_DEFAULT_PASS=sentiric_pass
RABBITMQ_URL="amqp://${RABBITMQ_DEFAULT_USER}:${RABBITMQ_DEFAULT_PASS}@${RABBITMQ_HOST}:${RABBITMQ_PORT}/%2f"

RABBITMQ_CHANNEL=call.events

# Cache
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL="redis://${REDIS_HOST}:${REDIS_PORT}/0" # Celery/Task Queue için
# ---

# AGENT_SERVICE
AGENT_SERVICE_HOST=agent-service
AGENT_SERVICE_PORT=0000
AGENT_SERVICE_URL="${AGENT_SERVICE_HOST}:${AGENT_SERVICE_PORT}"

# Agent Service Sertifikası
AGENT_SERVICE_CERT_PATH=/etc/sentiric/tls/agent-service-chain.crt
AGENT_SERVICE_KEY_PATH=/etc/sentiric/tls/agent-service.key

# API_GATEWAY_SERVICE
API_GATEWAY_SERVICE_HOST=api-gateway
API_GATEWAY_SERVICE_PORT=8080

# Api Gateway Service Sertifikası
API_GATEWAY_SERVICE_CERT_PATH=/etc/sentiric/tls/api-gateway-chain.crt
API_GATEWAY_SERVICE_KEY_PATH=/etc/sentiric/tls/api-gateway.key

# ASSETS
ASSETS_X=

# CDR_SERVICE
CDR_SERVICE_HOST=localhost
CDR_SERVICE_PORT=5004
CDR_SERVICE_URL="${CDR_SERVICE_HOST}:${CDR_SERVICE_PORT}"

CDR_QUEUE_NAME=call.events

CDR_SERVICE_CERT_PATH=/etc/sentiric/tls/certs/cdr-service-chain.crt
CDR_SERVICE_KEY_PATH=/etc/sentiric/tls/certs/cdr-service.key
GRPC_TLS_CA_PATH=/etc/sentiric/tls/certs/ca.crt

# CLI
CLI_X=

# CONNECTOR_SERVICE
CONNECTOR_SERVICE_HOST=connector-service
CONNECTOR_SERVICE_PORT=5005
CONNECTOR_SERVICE_URL="${CONNECTOR_SERVICE_HOST}:${CONNECTOR_SERVICE_PORT}"

# CONTRACTS
CONTRACTS_X=

# DASHBOARD_UI
DASHBOARD_UI_HOST=dashboard-ui
DASHBOARD_UI_PORT=3000
DASHBOARD_UI_URL="${DASHBOARD_UI_HOST}:${DASHBOARD_UI_PORT}"

# DB_MODELS
DB_MODELS_X=

# DIALPLAN_SERVICE
DIALPLAN_SERVICE_HOST=dialplan-service
DIALPLAN_SERVICE_PORT=3002
DIALPLAN_SERVICE_GRPC_PORT=50054

DIALPLAN_SERVICE_GRPC_URL="${DIALPLAN_SERVICE_HOST}:${DIALPLAN_SERVICE_GRPC_PORT}"

# Dialplan Service Sertifikası
DIALPLAN_SERVICE_CERT_PATH=/etc/sentiric/tls/dialplan-service-chain.crt
DIALPLAN_SERVICE_KEY_PATH=/etc/sentiric/tls/dialplan-service.key

# EMBEDDABLE_VOICE_WIDGET_SDK
EMBEDDABLE_VOICE_WIDGET_SDK_X=

# GOVERNANCE
GOVERNANCE_X=

# INFRASTRUCTURE
INFRASTRUCTURE_X=

# CA Sertifikası (Tüm servisler için aynı)
GRPC_TLS_CA_PATH=/etc/sentiric/tls/ca.crt

# EĞER QDRANT CLOUD KULLANIYORSANIZ, BU DEĞİŞKENİ .env DOSYANIZA EKLEYİN:
# QDRANT_API_KEY="your_qdrant_cloud_api_key_here"

# 12-Factor App" prensipleri.
SENTIRIC_DATA_PATH=data

# KNOWLEDGE_SERVICE
KNOWLEDGE_SERVICE_HOST=knowledge-service
KNOWLEDGE_SERVICE_PORT=50055
KNOWLEDGE_SERVICE_URL="${KNOWLEDGE_SERVICE_HOST}:${KNOWLEDGE_SERVICE_PORT}"

EMBEDDING_MODEL_NAME=${VECTOR_DB_EMBEDDING_MODEL_NAME}

KNOWLEDGE_SERVICE_CERT_PATH=/etc/sentiric/tls/knowledge-service-chain.crt
KNOWLEDGE_SERVICE_KEY_PATH=/etc/sentiric/tls/knowledge-service.key
GRPC_TLS_CA_PATH=/etc/sentiric/tls/certs/ca.crt

# LLM_SERVICE
LLM_SERVICE_HOST=llm-service
LLM_SERVICE_PORT=7860
LLM_SERVICE_URL="${LLM_SERVICE_HOST}:${LLM_SERVICE_PORT}"

LLM_SERVICE_CERT_PATH=/etc/sentiric/tls/llm-service-chain.crt
LLM_SERVICE_KEY_PATH=/etc/sentiric/tls/llm-service.key

# MARKETPLACE_SERVICE
MARKETPLACE_SERVICE_HOST=marketplace-service
MARKETPLACE_SERVICE_PORT=4000
MARKETPLACE_SERVICE_URL="${MARKETPLACE_SERVICE_HOST}:${MARKETPLACE_SERVICE_PORT}"

# MARKETPLACE_SERVICE
MARKETPLACE_SERVICE_HOST=marketplace-service
MARKETPLACE_SERVICE_PORT=4000
MARKETPLACE_SERVICE_URL="${MARKETPLACE_SERVICE_HOST}:${MARKETPLACE_SERVICE_PORT}"

MARKETPLACE_SERVICE_CERT_PATH=/etc/sentiric/tls/marketplace-service-chain.crt
MARKETPLACE_SERVICE_KEY_PATH=/etc/sentiric/tls/marketplace-service.key

# MEDIA_SERVICE
MEDIA_SERVICE_HOST=media-service
MEDIA_SERVICE_PORT=

MEDIA_SERVICE_GRPC_PORT=50052
MEDIA_SERVICE_GRPC_URL="${MEDIA_SERVICE_HOST}:${MEDIA_SERVICE_GRPC_PORT}"

# Media Service Sertifikası
MEDIA_SERVICE_CERT_PATH=/etc/sentiric/tls/media-service-chain.crt
MEDIA_SERVICE_KEY_PATH=/etc/sentiric/tls/media-service.key

## RTP_SERVICE
RTP_SERVICE_LISTEN_ADDRESS=0.0.0.0
RTP_SERVICE_PORT_QUARANTINE_SECONDS=5
RTP_SERVICE_PORT_MIN=10000
RTP_SERVICE_PORT_MAX=10100

ASSETS_BASE_PATH=assets

# MESSAGING_GATEWAY_SERVICE
MESSAGING_GATEWAY_SERVICE_HOST=messaging-gateway
MESSAGING_GATEWAY_SERVICE_PORT=3003
MESSAGING_GATEWAY_SERVICE_URL="${MESSAGING_GATEWAY_SERVICE_HOST}:${MESSAGING_GATEWAY_SERVICE_PORT}"

MESSAGING_GATEWAY_CERT_PATH=/etc/sentiric/tls/messaging-gateway-chain.crt
MESSAGING_GATEWAY_KEY_PATH=/etc/sentiric/tls/messaging-gateway.key

# SIP_CLIENT_SDK
SIP_CLIENT_SDK_X=

# SIP_GATEWAY_SERVICE
SIP_GATEWAY_SERVICE_HOST=sip-gateway
SIP_GATEWAY_SERVICE_PORT=5060
SIP_GATEWAY_SERVICE_URL="${SIP_GATEWAY_SERVICE_HOST}:${SIP_GATEWAY_SERVICE_PORT}"

SIP_GATEWAY_SERVICE_CERT_PATH=/etc/sentiric/tls/sip-gateway-chain.crt
SIP_GATEWAY_SERVICE_KEY_PATH=/etc/sentiric/tls/sip-gateway.key

# SIP_SIGNALING_SERVICE
SIP_SIGNALING_SERVICE_LISTEN_ADDRESS=0.0.0.0
SIP_SIGNALING_SERVICE_HOST=sip-signaling
SIP_SIGNALING_SERVICE_PORT=5060
SIP_SIGNALING_SERVICE_URL="${SIP_SIGNALING_SERVICE_HOST}:${SIP_SIGNALING_SERVICE_PORT}"

# SIP Signaling Service Sertifikası
SIP_SIGNALING_SERVICE_CERT_PATH=/etc/sentiric/tls/sip-signaling-chain.crt
SIP_SIGNALING_SERVICE_KEY_PATH=/etc/sentiric/tls/sip-signaling.key

# STT_SERVICE
STT_SERVICE_HOST=stt-service
STT_SERVICE_PORT=5001
STT_SERVICE_URL="${STT_SERVICE_HOST}:${STT_SERVICE_PORT}"

STT_SERVICE_GRPC_PORT=50050
STT_SERVICE_GRPC_URL="${STT_SERVICE_HOST}:${STT_SERVICE_GRPC_PORT}"

STT_SERVICE_MODEL_NAME=whisper-base
STT_SERVICE_MODEL_DEVICE=MODEL_DEVICE=cpu

STT_SERVICE_CERT_PATH=/etc/sentiric/tls/stt-service-chain.crt
STT_SERVICE_KEY_PATH=/etc/sentiric/tls/stt-service.key

# --- ADAPTÖR SEÇİMİ ---
STT_ADAPTER="faster_whisper"

# --- FASTER-WHISPER AYARLARI ---
STT_MODEL_SIZE=base
STT_DEVICE=cpu
STT_COMPUTE_TYPE=int8

# TASK_SERVICE
TASK_SERVICE_HOST=task-service
TASK_SERVICE_PORT=5003
TASK_SERVICE_URL="${TASK_SERVICE_HOST}:${TASK_SERVICE_PORT}"

TASK_SERVICE_CERT_PATH=/etc/sentiric/tls/task-service-chain.crt
TASK_SERVICE_KEY_PATH=/etc/sentiric/tls/task-service.key

# TELEPHONY_GATEWAY_SERVICE
TELEPHONY_GATEWAY_SERVICE_HOST=telephony-gateway
TELEPHONY_GATEWAY_SERVICE_PORT=
TELEPHONY_GATEWAY_SERVICE_URL="${TELEPHONY_GATEWAY_SERVICE_HOST}:${TELEPHONY_GATEWAY_SERVICE_PORT}"

# TTS_SERVICE
TTS_SERVICE_HOST=tts-service
TTS_SERVICE_PORT=5002
TTS_SERVICE_URL="${TTS_SERVICE_HOST}:${TTS_SERVICE_PORT}"

TTS_SERVICE_GRPC_PORT=50051
TTS_SERVICE_GRPC_URL="${TTS_SERVICE_HOST}:${TTS_SERVICE_GRPC_PORT}"

# --- Coqui XTTS Modeli Ayarları ---
# Hugging Face'ten indirilecek modelin adı
TTS_SERVICE_MODEL_NAME="tts_models/multilingual/multi-dataset/xtts_v2"

# Kullanılacak cihaz: "cpu" veya "cuda" (eğer NVIDIA GPU varsa)
# "auto" seçeneği, varsa GPU'yu otomatik olarak seçer.
TTS_SERVICE_MODEL_DEVICE="auto"

# Varsayılan konuşmacı sesi için, konteyner içindeki referans .wav dosyasının yolu.
TTS_SERVICE_DEFAULT_SPEAKER_WAV_PATH="/app/docs/audio/speakers/tr/default_male.wav"

# --- Güvenlik (mTLS) Ayarları (gelecekteki gRPC kullanımı için) ---
TTS_SERVICE_CERT_PATH=/etc/sentiric/tls/tts-service-chain.crt
TTS_SERVICE_KEY_PATH=/etc/sentiric/tls/tts-service.key

# --- ElevenLabs Entegrasyonu ---
# Alternatif bir TTS motoru olarak ElevenLabs'i etkinleştirmek için
# aşağıdaki değişkenlerin başındaki yorumu kaldırın ve doldurun.
#
# ENABLE_ELEVENLABS_TTS="true"
# ELEVENLABS_API_KEY="sk_your_elevenlabs_api_key_here"
# ELEVENLABS_VOICE_ID="pNInz6obpgDQGxUGXP57" # Örnek: Rachel

# USER_SERVICE
USER_SERVICE_HOST=user-service
USER_SERVICE_PORT=
USER_SERVICE_URL="${USER_SERVICE_HOST}:${USER_SERVICE_PORT}"

USER_SERVICE_GRPC_PORT=50053
USER_SERVICE_GRPC_URL="${USER_SERVICE_HOST}:${USER_SERVICE_GRPC_PORT}"

# User Service Sertifikası
USER_SERVICE_CERT_PATH=/etc/sentiric/tls/user-service-chain.crt
USER_SERVICE_KEY_PATH=/etc/sentiric/tls/user-service.key

# WEB_AGENT
WEB_AGENT_UI_HOST=web-agent-ui
WEB_AGENT_UI_PORT=3001
WEB_AGENT_UI_URL="${WEB_AGENT_UI_HOST}:${WEB_AGENT_UI_PORT}"

WEB_AGENT_UI_CERT_PATH=/etc/sentiric/tls/web-agent-ui-chain.crt
WEB_AGENT_UI_KEY_PATH=/etc/sentiric/tls/web-agent-ui.key

# --- Metrik Sunucusu Portu ---
METRICS_PORT=9092

# ---

# Harici Servis Bilgileri
GOOGLE_API_KEY="YOUR_GOOGLE_AI_STUDIO_API_KEY_HERE"
GOOGLE_CALENDAR_API_KEY=your_google_calendar_api_key
WHATSAPP_API_TOKEN=your_whatsapp_api_token
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
DEEPGRAM_API_KEY="YOUR_DEEPGRAM_API_KEY_HERE"
ELEVENLABS_API_KEY="YOUR_ELEVENLABS_API_KEY_HERE"
ELEVENLABS_VOICE_ID="pNInz6obpgDQGxUGXP57"
SALESFORCE_API_KEY=your_salesforce_api_key

LLM_PROVIDER=gemini
LLM_API_KEY="AIzaSy..."
LLM_MODEL_NAME="gemini-1.5-flash"
AI_SERVICE_TIMEOUT=10