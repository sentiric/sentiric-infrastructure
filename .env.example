# === ÜRETİM ORTAMI İÇİN TAM KONFİGÜRASYON ŞABLONU ===
# Bu şablon, her sunucuya kopyalanıp o sunucuya özel IP'lerle doldurulur.

# -- Güvenli Üretim Şifreleri --
POSTGRES_USER=sentiric_prod
POSTGRES_PASSWORD=COK_GUVENLI_URETIM_SIFRESI_1
POSTGRES_DB=sentiric_prod_db
RABBITMQ_DEFAULT_USER=sentiric_prod
RABBITMQ_DEFAULT_PASS=COK_GUVENLI_URETIM_SIFRESI_2

# -- Sunucu IP Adresleri --
ORACLE_TELEKOM_PUBLIC_IP=141.148.224.123
ORACLE_APP_PRIVATE_IP=10.0.0.238
GCP_DATA_PUBLIC_IP=34.122.40.122

# -- Servislerin Birbirleriyle Konuşması İçin URL'ler --
# NOT: Burada Docker servis adları yerine IP adresleri kullanılır.

# agent-service için (Sunucu 2'de)
AGENT_RABBITMQ_HOST=${GCP_DATA_PUBLIC_IP}
AGENT_MEDIA_SERVICE_URL=http://${ORACLE_TELEKOM_PUBLIC_IP}:3003

# user-service için (Sunucu 2'de)
USER_DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${GCP_DATA_PUBLIC_IP}:5432/${POSTGRES_DB}

# sip-signaling için (Sunucu 1'de)
SIP_PORT=5060
PUBLIC_IP=${ORACLE_TELEKOM_PUBLIC_IP}
SIP_RABBITMQ_URL=amqp://${RABBITMQ_DEFAULT_USER}:${RABBITMQ_DEFAULT_PASS}@${GCP_DATA_PUBLIC_IP}:5672
SIP_USER_SERVICE_URL=http://${ORACLE_APP_PRIVATE_IP}:3001
SIP_DIALPLAN_SERVICE_URL=http://${ORACLE_APP_PRIVATE_IP}:3002
SIP_MEDIA_SERVICE_URL=http://127.0.0.1:3003 # Kendisiyle aynı makinede