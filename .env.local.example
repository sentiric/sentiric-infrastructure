# ====================================================================
#          SENTIRIC PLATFORMU - ORTAM DEĞİŞKENLERİ
# ====================================================================
# Bu dosya, 'local' geliştirme ortamı için bir şablondur.
# 'cp .env.local.example .env' komutuyla kendi .env dosyanızı oluşturun.
# ====================================================================

# --- DAĞITIM MODU ---
# 'local' veya 'production' olabilir. Bu, kaynak adlarını etkiler.
ENV=production

# --- AĞ YAPILANDIRMASI ---
NETWORK_NAME=sentiric-net-${ENV}
NETWORK_DRIVER=bridge

# --- SERVİS HOSTLARI ---
# 'local' modda, tüm servisler Docker ağı içinde birbirlerine servis adıyla (örn: 'rabbitmq') erişir.
# Bu yüzden IP yerine servis adları kullanılır.
# Production'da bu değerler gerçek sunucu IP'leri olacaktır.
DATA_HOST=rabbitmq
APP_HOST=user-service # Örnek, gRPC URL'leri daha spesifik

# --- DIŞ DÜNYA ERİŞİMİ ---
# Bu IP, SIP sağlayıcısının ve dünyanın sizin sisteminize ulaşacağı genel IP adresidir.
# Yerel testler için '127.0.0.1' veya makinenizin yerel IP'si olabilir.
PUBLIC_IP=127.0.0.1

# ==================== VERİ SERVİSLERİ (DATA SERVICES) ====================
POSTGRES_DB=sentiric_${ENV}_db
POSTGRES_USER=sentiric
POSTGRES_PASSWORD=sentiric_pass

RABBITMQ_USER=sentiric
RABBITMQ_PASS=sentiric_pass
RABBITMQ_ERLANG_COOKIE=AEJSDJSKQWOPJZ0123SADASD

# ==================== SERVİSLERİN KULLANACAĞI TAM URL'LER ====================
# Servisler, Docker ağı içinde birbirlerine doğrudan servis adıyla erişir.
# Bu, en sağlam ve esnek yöntemdir.

# --- Veritabanı ve Mesajlaşma URL'leri ---
# Not: Host adı olarak IP yerine servis adı ('postgres', 'rabbitmq') kullanılır.
POSTGRES_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}?sslmode=disable
RABBITMQ_URL=amqp://${RABBITMQ_USER}:${RABBITMQ_PASS}@rabbitmq:5672/%2f
REDIS_URL=redis://:sentiric@localhost:6379/2
MONGO_URL=mongodb://localhost:27017/sentiric

# --- gRPC Servis Uç Noktaları (Endpoints) ---
# Diğer servisler bu URL'leri kullanarak gRPC servislerine bağlanacak.
# Not: Rust ve Go gRPC kütüphaneleri genellikle 'http://' prefix'ine ihtiyaç duymaz,
# ama netlik için eklemek iyi bir pratiktir.
USER_SERVICE_GRPC_URL=user-service:50053
DIALPLAN_SERVICE_GRPC_URL=dialplan-service:50054
MEDIA_SERVICE_GRPC_URL=media-service:50052

# ==================== SERVİS ÖZEL AYARLARI ====================

# --- SIP Signaling Service ---
SIP_HOST=0.0.0.0 # Konteynerin tüm arayüzlerini dinlemesi için
SIP_PORT=5060

# --- Media Service ---
RTP_HOST=0.0.0.0 # Konteynerin tüm arayüzlerini dinlemesi için
RTP_PORT_MIN=10000
RTP_PORT_MAX=10010
GRPC_PORT_MEDIA=50052 # Media service'in kendi gRPC portu

# --- User Service ---
GRPC_PORT_USER=50053 # User service'in kendi gRPC portu

# --- Dialplan Service ---
GRPC_PORT_DIALPLAN=50054 # Dialplan service'in kendi gRPC portu