# ==========================================================
# SENTIRIC PLATFORM - LOCAL DEVELOPMENT ENVIRONMENT
# ==========================================================
# Copy this file to .env and customize for your local setup.

# --- Global Settings ---
DOCKER_REGISTRY=ghcr.io/sentiric
TAG=latest
NETWORK_NAME=sentiric-net

# --- PostgreSQL ---
POSTGRES_DB=sentiric_db
POSTGRES_USER=sentiric_user
POSTGRES_PASSWORD=sentiric_pass

# --- RabbitMQ ---
RABBITMQ_DEFAULT_USER=sentiric
RABBITMQ_DEFAULT_PASS=sentiric_pass
RABBITMQ_URL=amqp://sentiric:sentiric_pass@rabbitmq:5672/%2f

# --- SIP Signaling Service (Rust) ---
SIP_HOST=0.0.0.0
SIP_PORT=5060
# IMPORTANT: This must be the IP address that external SIP clients/proxies can reach.
# For local testing, 127.0.0.1 is fine. For a server, this MUST be its public IP.
PUBLIC_IP=127.0.0.1

# --- Media Service (Rust) ---
GRPC_HOST_MEDIA=0.0.0.0
GRPC_PORT_MEDIA=50052
RTP_HOST=0.0.0.0
RTP_PORT_MIN=10000
RTP_PORT_MAX=10100

# --- User Service (Go) ---
GRPC_PORT_USER=50053

# --- Dialplan Service (Go) ---
GRPC_PORT_DIALPLAN=50054

# --- Agent Service (Python) ---
# No specific variables for now, it uses RABBITMQ_URL.

# --- gRPC URLs for Inter-Service Communication ---
# These are used by services to connect to each other within the Docker network.
USER_SERVICE_GRPC_URL=http://user-service:50053
DIALPLAN_SERVICE_GRPC_URL=http://dialplan-service:50054
MEDIA_SERVICE_GRPC_URL=http://media-service:50052