# ====================================================================
#          SENTIRIC PLATFORMU - LOKAL GELİŞTİRME ORTAMI
# ====================================================================
# Bu dosya, 'local' geliştirme ortamı için TEK DOĞRULUK KAYNAĞIDIR.
# ====================================================================

# --- AĞ YAPILANDIRMASI ---
NETWORK_NAME=sentiric-net
NETWORK_DRIVER=bridge
PUBLIC_IP=127.0.0.1

# ==================== VERİ KATMANI SERVİSLERİ ====================
# --- PostgreSQL ---
POSTGRES_DB=sentiric_db
POSTGRES_USER=sentiric
POSTGRES_PASSWORD=sentiric_pass
POSTGRES_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}?sslmode=disable

# --- RabbitMQ ---
RABBITMQ_USER=sentiric
RABBITMQ_PASS=sentiric_pass
RABBITMQ_URL=amqp://${RABBITMQ_USER}:${RABBITMQ_PASS}@rabbitmq:5672/%2f

# ==================== UYGULAMA SERVİSLERİ PORTLARI ====================
# --- gRPC Portları (Dahili İletişim) ---
GRPC_PORT_MEDIA=50052
GRPC_PORT_USER=50053
GRPC_PORT_DIALPLAN=50054


# --- gRPC Servis Adresleri (Diğer servislerin kullanması için) ---
# DÜZELTME: Tüm servislerle uyumluluk için 'http://' şeması eklendi.
MEDIA_SERVICE_GRPC_URL=http://media-service:${GRPC_PORT_MEDIA}
USER_SERVICE_GRPC_URL=http://user-service:${GRPC_PORT_USER}
DIALPLAN_SERVICE_GRPC_URL=http://dialplan-service:${GRPC_PORT_DIALPLAN}


# --- Ağ Geçidi Servisleri Portları (Dış Dünya) ---
SIP_PORT=5060

# --- Medya Servisi RTP Port Aralığı ---
RTP_PORT_MIN=10000
RTP_PORT_MAX=10010