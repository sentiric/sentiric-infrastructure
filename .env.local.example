# === MODE ===
MODE=local

# === NETWORK ===
NETWORK_NAME=sentiric-dev
NETWORK_DRIVER=bridge

# === DATA SERVICES ===
POSTGRES_DB=sentiric_dev
POSTGRES_USER=dev_user
POSTGRES_PASSWORD=dev_pass
POSTGRES_URL=postgres://dev_user:dev_pass@postgres:5432/sentiric_dev

RABBITMQ_USER=dev_user
RABBITMQ_PASS=dev_pass
RABBITMQ_URL=amqp://dev_user:dev_pass@rabbitmq:5672/%2f

REDIS_URL=redis://redis:6379
MONGO_URL=mongodb://mongodb:27017/sentiric

# === TELECOM ===
SIP_HOST=0.0.0.0
SIP_PORT=5060
PUBLIC_IP=127.0.0.1
RTP_PORT_MIN=10000
RTP_PORT_MAX=10100

# === SERVICE ENDPOINTS ===
USER_SERVICE_URL=http://user-service:50051
MEDIA_GRPC_PORT=50052
USER_GRPC_PORT=50051