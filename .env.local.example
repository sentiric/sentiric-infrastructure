# === YEREL GELİŞTİRME ORTAMI İÇİN TAM KONFİGÜRASYON ===
# Bu .env dosyası, 'sentiric-infrastructure' dizinine kopyalanır ve
# 'docker compose up' komutuyla tüm platformu tek makinede çalıştırır.

# -- Temel Altyapı Şifreleri --
POSTGRES_USER=sentiric
POSTGRES_PASSWORD=local_postgres_pass
POSTGRES_DB=sentiric_db
RABBITMQ_DEFAULT_USER=sentiric
RABBITMQ_DEFAULT_PASS=local_rabbit_pass

# -- Servislerin Birbirleriyle Konuşması İçin URL'ler --
# NOT: Burada IP yerine Docker servis adları kullanılır.

# agent-service için gerekenler
AGENT_RABBITMQ_HOST=rabbitmq
AGENT_MEDIA_SERVICE_URL=http://media-service:3003

# user-service için gerekenler
USER_DATABASE_URL=postgresql://sentiric:local_postgres_pass@postgres:5432/sentiric_db

# sip-signaling için gerekenler
SIP_PORT=5060
PUBLIC_IP=127.0.0.1 # Yerel test için
SIP_RABBITMQ_URL=amqp://sentiric:local_rabbit_pass@rabbitmq:5672
SIP_USER_SERVICE_URL=http://user-service:3001
SIP_DIALPLAN_SERVICE_URL=http://dialplan-service:3002
SIP_MEDIA_SERVICE_URL=http://media-service:3003