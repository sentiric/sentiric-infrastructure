# ====================================================================
#          SENTIRIC PLATFORMU - LOKAL GELİŞTİRME ORTAMI
# ====================================================================
# Bu dosya, 'local' geliştirme ortamı için TEK DOĞRULUK KAYNAĞIDIR.
# 'cp .env.local.example .env' komutuyla kendi .env dosyanızı oluşturun.
# ====================================================================

# --- AĞ YAPILANDIRMASI ---
NETWORK_NAME=sentiric-net
NETWORK_DRIVER=bridge
# Bu IP, SIP sağlayıcısının (örn: softphone) ve dünyanın sisteminize ulaşacağı IP'dir.
# LOKAL geliştirme için bu genellikle makinenizin yerel ağıdaki IP'si veya 127.0.0.1'dir.
# Docker Desktop kullanıyorsanız, PUBLIC_IP=host.docker.internal da bir seçenek olabilir.
PUBLIC_IP=127.0.0.1

# ==================== VERİ KATMANI SERVİSLERİ ====================
# --- PostgreSQL ---
POSTGRES_DB=sentiric_db
POSTGRES_USER=sentiric
POSTGRES_PASSWORD=sentiric_pass
# Servislerin PostgreSQL'e bağlanmak için kullanacağı TAM BAĞLANTI ADRESİ.
# Dikkat: Host adı 'localhost' değil, docker-compose içindeki servis adı olan 'postgres'tir.
POSTGRES_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}?sslmode=disable

# --- RabbitMQ ---
RABBITMQ_USER=sentiric
RABBITMQ_PASS=sentiric_pass
# Servislerin RabbitMQ'ya bağlanmak için kullanacağı TAM BAĞLANTI ADRESİ.
RABBITMQ_URL=amqp://${RABBITMQ_USER}:${RABBITMQ_PASS}@rabbitmq:5672/

# ==================== UYGULAMA SERVİSLERİ PORTLARI ====================
# --- gRPC Portları (Dahili İletişim) ---
# Bu portlar, servislerin Docker ağı İÇİNDE birbirleriyle konuşacağı portlardır.
GRPC_PORT_USER=50053
GRPC_PORT_DIALPLAN=50054
GRPC_PORT_MEDIA=50052

# --- gRPC Servis Adresleri (Diğer servislerin kullanması için) ---
# Dikkat: Host adı olarak servis adları kullanılır. Kütüphanelerin 'http://' istemediğini varsayıyoruz.
USER_SERVICE_GRPC_URL=user-service:${GRPC_PORT_USER}
DIALPLAN_SERVICE_GRPC_URL=dialplan-service:${GRPC_PORT_DIALPLAN}
MEDIA_SERVICE_GRPC_URL=media-service:${GRPC_PORT_MEDIA}

# --- Ağ Geçidi Servisleri Portları (Dış Dünya) ---
SIP_PORT=5060

# --- Medya Servisi RTP Port Aralığı ---
RTP_PORT_MIN=10000
RTP_PORT_MAX=10010