# SENTIRIC PLATFORM - PRODUCTION ENVIRONMENT EXAMPLE
# ---------------------------------------------------
# Copy this file to .env.prod on your servers and fill in the actual values.

# --- Global Settings ---
# Use a specific version tag in production
TAG=v0.1.0

# --- RabbitMQ ---
# Use the IP address of the Data Server
RABBITMQ_URL=amqp://sentiric:your_prod_pass@10.0.0.3:5672/%2f

# --- SIP Signaling Service ---
SIP_PORT=5060
# IMPORTANT: This MUST be the public IP of the Telekom Gateway Server
PUBLIC_IP=YOUR_TELEKOM_SERVER_PUBLIC_IP

# --- gRPC URLs for Inter-Service Communication ---
# Use the internal IP addresses of the servers where the services are running
USER_SERVICE_GRPC_URL=http://app-server-ip:50053
DIALPLAN_SERVICE_GRPC_URL=http://app-server-ip:50054
MEDIA_SERVICE_GRPC_URL=http://telekom-server-ip:50052