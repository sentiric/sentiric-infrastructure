# === MODE ===
MODE=production

# === NETWORK ===
NETWORK_NAME=sentiric-prod
NETWORK_DRIVER=bridge

# === DATA SERVICES ===
POSTGRES_DB=sentiric_prod
POSTGRES_USER=prod_user
POSTGRES_PASSWORD=secure_password123
POSTGRES_URL=postgres://prod_user:secure_password123@localhost:5432/sentiric_prod

RABBITMQ_USER=prod_user
RABBITMQ_PASS=secure_password123
RABBITMQ_URL=amqp://prod_user:secure_password123@localhost:5672/%2f

REDIS_URL=redis://localhost:6379
MONGO_URL=mongodb://localhost:27017/sentiric

# === EXTERNAL ACCESS ===
EXTERNAL_POSTGRES_URL=postgres://prod_user:secure_password123@<DATA_SERVER_IP>:5432
EXTERNAL_RABBITMQ_URL=amqp://prod_user:secure_password123@<DATA_SERVER_IP>:5672/%2f